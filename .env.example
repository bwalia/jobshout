# -----------------------------------------------------------------------------
# JobShout environment
# -----------------------------------------------------------------------------
# Host port mappings (chosen to avoid conflicts with other services on the
# shared self-hosted runner VM 192.168.1.193 where 8080/8090/9000/9001/11434
# are already in use).
UI_HOST_PORT=3001
SERVER_HOST_PORT=8190
POSTGRES_HOST_PORT=5433
MINIO_API_HOST_PORT=9100
MINIO_CONSOLE_HOST_PORT=9110
# OLLAMA_HOST_PORT intentionally unset — we use the host's Ollama on :11434
# directly rather than running a compose-managed instance.

# PostgreSQL (container-internal URL – unchanged inside the compose network)
POSTGRES_USER=jobshout
POSTGRES_PASSWORD=jobshout
POSTGRES_DB=jobshout
DATABASE_URL=postgres://jobshout:jobshout@postgres:5432/jobshout?sslmode=disable

# JWT
JWT_SECRET=change-me-to-a-random-32-character-string
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# MinIO (container-internal endpoint)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_KNOWLEDGE=knowledge

# Server
SERVER_PORT=:8080
# Comma-separated list of allowed CORS origins. Include the public dev domain
# and LAN origins so browsers hitting either can call the API.
CORS_ORIGINS=https://dev.jobshout.co.uk,http://localhost:3001,http://192.168.1.193:3001

# Next.js – browser-facing URLs (must be reachable from the user's browser).
# Uses the public HTTPS dev domain; wss:// avoids mixed-content blocking.
NEXT_PUBLIC_API_URL=https://dev-api.jobshout.co.uk
NEXT_PUBLIC_WS_URL=wss://dev-api.jobshout.co.uk

# -----------------------------------------------------------------------------
# Automated blog generator (GitHub PR pipeline)
# -----------------------------------------------------------------------------
# When GITHUB_TOKEN is set, the server enables POST /api/v1/blogs/generate,
# which: calls the LLM to write markdown blog posts, commits them to a new
# branch on bwalia/workstation-website, and opens a PR. Leave unset to
# disable the feature. Token needs repo scope (or fine-grained Contents+PRs).
GITHUB_TOKEN=
GITHUB_USER_NAME=JobShout Bot
GITHUB_USER_EMAIL=bot@jobshout.local
BLOG_REPO_OWNER=bwalia
BLOG_REPO_NAME=workstation-website
BLOG_BASE_BRANCH=main
BLOG_WORK_DIR=/tmp/jobshout-blog

# LLM / sidecar
# Containers reach the host's Ollama via host.docker.internal (mapped via
# extra_hosts) so we reuse the models already pulled on the host box.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3:latest
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini
PYTHON_SIDECAR_URL=http://python-sidecar:8001
PYTHON_SIDECAR_SECRET=change-me-sidecar-secret
