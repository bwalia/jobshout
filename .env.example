# -----------------------------------------------------------------------------
# JobShout environment
# -----------------------------------------------------------------------------
# Host port mappings (chosen to avoid conflicts with other services on the
# shared self-hosted runner VM 192.168.1.193 where 8080/8090/9000/9001/11434
# are already in use).
UI_HOST_PORT=3001
SERVER_HOST_PORT=8190
POSTGRES_HOST_PORT=5433
MINIO_API_HOST_PORT=9100
MINIO_CONSOLE_HOST_PORT=9110
OLLAMA_HOST_PORT=11440

# PostgreSQL (container-internal URL – unchanged inside the compose network)
POSTGRES_USER=jobshout
POSTGRES_PASSWORD=jobshout
POSTGRES_DB=jobshout
DATABASE_URL=postgres://jobshout:jobshout@postgres:5432/jobshout?sslmode=disable

# JWT
JWT_SECRET=change-me-to-a-random-32-character-string
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# MinIO (container-internal endpoint)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_KNOWLEDGE=knowledge

# Server
SERVER_PORT=:8080
# Comma-separated list of allowed CORS origins. Include the LAN origin so
# browsers on 192.168.1.0/24 hitting the deployed UI can call the API.
CORS_ORIGINS=http://localhost:3001,http://192.168.1.193:3001

# Next.js – browser-facing URLs (must be reachable from the user's browser)
NEXT_PUBLIC_API_URL=http://192.168.1.193:8190
NEXT_PUBLIC_WS_URL=ws://192.168.1.193:8190

# LLM / sidecar
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=tinyllama
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini
PYTHON_SIDECAR_URL=http://python-sidecar:8001
PYTHON_SIDECAR_SECRET=change-me-sidecar-secret
