{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Total Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(jobshout_cost_usd_total)",
          "legendFormat": "Total Cost",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cost by Provider",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (provider) (jobshout_cost_usd_total)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Budget Utilization",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "orange", "value": 0.85 },
              { "color": "red", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jobshout_budget_usage_ratio{org_id=~\"$org_id\"}",
          "legendFormat": "{{period}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Budget Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(jobshout_budget_alert_total[24h]))",
          "legendFormat": "Alerts (24h)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cost Over Time (by Provider)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (provider) (increase(jobshout_cost_usd_total[$__rate_interval]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cost Over Time (by Model)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (model) (increase(jobshout_cost_usd_total[$__rate_interval]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Token Usage (Input vs Output)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (direction) (increase(jobshout_token_usage_total[$__rate_interval]))",
          "legendFormat": "{{direction}} tokens",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Policy Blocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (reason) (increase(jobshout_policy_block_total[$__rate_interval]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["jobshout", "cost", "finops"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(jobshout_cost_usd_total, org_id)",
        "name": "org_id",
        "type": "query",
        "includeAll": true,
        "multi": false
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "title": "JobShout - Cost Overview",
  "uid": "jobshout-cost-overview"
}
